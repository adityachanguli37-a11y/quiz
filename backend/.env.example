# Server Configuration
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# Database
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/cyber_quiz

# Authentication
JWT_ACCESS_SECRET=your_jwt_access_secret_key_change_me_in_prod_32chars_or_more
JWT_REFRESH_SECRET=your_jwt_refresh_secret_key_change_me_in_prod_32chars_or_more

# Nodemailer SMTP Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_email_password
EMAIL_FROM="Cybersecurity Platform" <noreply@yourdomain.com>
