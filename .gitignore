# ──────────────────────────────────────────────
# Root .gitignore — CyberShield Assessment Portal
# ──────────────────────────────────────────────

# Dependencies
node_modules/
.pnp/
.pnp.js

# Environment secrets — NEVER commit real .env files
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Build outputs
dist/
build/
.next/
out/

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# OS artefacts
.DS_Store
Thumbs.db
desktop.ini

# Editor / IDE
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Test coverage
coverage/

# Misc
*.tgz
*.zip
